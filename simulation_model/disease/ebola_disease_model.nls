

;BASIC EBOLA IMPLEMENTATION, disease progression


to-report transition-ebo [s]

  ;static states: susceptible (healthy), and buried deceased
  if s = susceptible-infection-status [report stochastic-fsm-transition (list (list susceptible-infection-status 1))]
  if s = unsafe-burial-to-removed-infection-status [report stochastic-fsm-transition (list (list unsafe-burial-to-removed-infection-status 1))]
  if s = safe-burial-to-removed-infection-status [report stochastic-fsm-transition (list (list safe-burial-to-removed-infection-status 1))]

  
  ;dynamic: to do: adjust tau values and logic HERE!!
  ;list only
  ;exposed to stages 1
  if s = just-exposed-infection-status [report stochastic-fsm-transition (list (list exposed-to-stage-one-infection-status ))] ;everyexposed will develop symptoms
  ;stage 1 to stage 2
  if s = exposed-to-stage-one-infection-status [report stochastic-fsm-transition (list (list stage-one-to-stage-two-infection-status ))] ;try 50%
  
  ;stage 2 to hospital or not
  ;if s = stage-one-to-stage-two-infection-status [report stochastic-fsm-transition (list (list stage-two-to-hospitalised-infection-status ))]
  if s = stage-one-to-stage-two-infection-status [report stochastic-fsm-transition (list (list stage-two-to-non-hospitalised-infection-status ))]
  
  ;hospital to recovery
  if s = stage-one-to-hospitalised-infection-status [report stochastic-fsm-transition (list (list hospitalised-to-immune-infection-status ))] ;;here we assume that people who go to the hospital early will recover (unreal)

  ;hospital to death
  if s = stage-two-to-hospitalised-infection-status [report stochastic-fsm-transition (list (list hospitalized-to-dead-infectious-infection-status ))]

  ;no hospital to death
  if s = stage-two-to-non-hospitalised-infection-status [report stochastic-fsm-transition (list (list non-hospitalized-to-dead-infectious-infection-status ))]

  ;;death to safe or unsafe burial
  if s = hospitalized-to-dead-infectious-infection-status [
  ifelse trust-in-institutions [report stochastic-fsm-transition (list(list dead-to-safe-burial-infection-status))] ;temporary global var trust-in-institutions replaces agent belief systems
    [report stochastic-fsm-transition (list(list dead-to-unsafe-burial-infection-status))]
  ]
        print "sus static"
  ;;death to safe or unsafe burial
  if s = non-hospitalized-to-dead-infectious-infection-status [
  ifelse trust-in-institutions [report stochastic-fsm-transition (list(list dead-to-safe-burial-infection-status))] ;temporary global var trust-in-institutions replaces agent belief systems
    [report stochastic-fsm-transition (list(list dead-to-unsafe-burial-infection-status))]
  ]

  if is-timed-state? s and time-of-timed-state s > 0 [
    report stochastic-fsm-transition (list 
    (list timed-state state-of-timed-state s (time-of-timed-state s - 1)))
  ]  

  error (sentence "unimplemented" s)
  
end



