to-report next-state-ebo [s]
  report stochastic-transition-apply transition-ebo s
end


;these numbers are made up and need to be calibrated later
to-report p-pre-symptomatic-to-one-ebo
  report 1 ; ALL INFECTED WILL PROCEED TO STAGE ONE
end


to-report p-hosp-ebo
  ;INSTEAD OF AGE, THIS DEPENDS ON TRUST IN HOSPITAL SLIDER VALUE
  report trust_in_hospital ;expand this later, good for testing now
end

to-report tau-hosp-ebo
  report 10  * #ticks-per-day
end

;it takes very long for a patient to recover
to-report tau-hosp-rec-ebo
  let mean-val ((59 + 270) / 2)
  let variance-val 5
  report round (random-gamma (mean-val * mean-val / variance-val) (1 / (variance-val / mean-val)))  * #ticks-per-day
end

;how log does it take for a person to die
to-report tau-hospital-to-death-ebo
  report 10 * #ticks-per-day

end

;probability of survival, using the inverse of latest case fatality rate, adjust
to-report p-survival-in-hospital-ebo
  report 1 - CFR ; not real
end
  
;assuming people who do not go to the hospital will not survive
